    local Knob=Instance.new("Frame",Tr)
    Knob.Size=UDim2.new(0,kSz,0,kSz); Knob.Position=UDim2.new(r0,-kSz/2,0.5,-kSz/2)
    Knob.BackgroundColor3=C.accent; Knob.BorderSizePixel=0; Knob.ZIndex=5; Corner(kSz,Knob)

    local function SetVal(v)
        local r=math.clamp((v-minV)/(maxV-minV),0,1)
        Fill.Size=UDim2.new(r,0,1,0); Knob.Position=UDim2.new(r,-kSz/2,0.5,-kSz/2)
        local col=Locked() and C.sub or C.accent
        Fill.BackgroundColor3=col; Knob.BackgroundColor3=col; UpdLbl(v)
    end
    sliderRefs[key]=SetVal

    local function Apply(sx)
        local w=TrHit.AbsoluteSize.X; if w==0 then return end
        local r=math.clamp((sx-TrHit.AbsolutePosition.X)/w,0,1)
        S[key]=math.floor((minV+(maxV-minV)*r)*1000+0.5)/1000
        Fill.Size=UDim2.new(r,0,1,0); Knob.Position=UDim2.new(r,-kSz/2,0.5,-kSz/2); UpdLbl(S[key])
    end

    TrHit.InputBegan:Connect(function(i)
        local t=i.UserInputType
        if t~=Enum.UserInputType.MouseButton1 and t~=Enum.UserInputType.Touch then return end
        if Locked() then return end
        _slide=Apply; Apply(i.Position.X)
    end)
    Knob.InputBegan:Connect(function(i)
        local t=i.UserInputType
        if t~=Enum.UserInputType.MouseButton1 and t~=Enum.UserInputType.Touch then return end
        if Locked() then return end
        _slide=Apply
    end)
end

