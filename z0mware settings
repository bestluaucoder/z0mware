-- ═══════════════════════════════════════ PING / FPS ══
local smoothPing = 20; local peakPing = 20; local displayPing = 20
local pingBuf = {}; local pingPtr = 1; local PING_WIN = 30
for i=1,PING_WIN do pingBuf[i]=20 end

local smoothFPS = 60; local rawFPS = 60; local fpsLow = false
local dtBuf = {}; local dtPtr = 1; local DT_WIN = 20; local dtVar = 0
for i=1,DT_WIN do dtBuf[i]=1/60 end

local function UpdatePing()
    local raw = LP:GetNetworkPing() * 1000
    pingBuf[pingPtr] = raw; pingPtr = pingPtr % PING_WIN + 1
    smoothPing = smoothPing + 0.10 * (raw - smoothPing)
    local pk = 0
    for _, v in ipairs(pingBuf) do if v > pk then pk = v end end
    peakPing = pk; displayPing = smoothPing
end

local function UpdateFPS(dt)
    rawFPS = dt > 0 and 1/dt or 60
    smoothFPS = smoothFPS + 0.12 * (rawFPS - smoothFPS)
    fpsLow = smoothFPS < 45
    dtBuf[dtPtr] = dt; dtPtr = dtPtr % DT_WIN + 1
    local m = 0
    for _, v in ipairs(dtBuf) do m = m + v end; m = m / DT_WIN
    local s = 0
    for _, v in ipairs(dtBuf) do s = s + (v-m)^2 end
    dtVar = s / DT_WIN
end

-- ════════════════════════════ AERO DETECTION ══
-- Detects the "Aerodynamic Slash" ability which spikes the ball's speed.
-- Uses an EMA baseline; when a 1.68× spike is seen → detected.
local aeroDetected = false
local aeroExpiry   = 0
local aeroBase     = 0
local aeroPeak     = 0
local AERO_SPIKE   = 1.68
local AERO_MIN     = 35    -- u/s baseline minimum before trusting

local function UpdateAero(ball)
    if not S.AeroDetect then aeroDetected = false; return end
    local z = ball:FindFirstChild("zoomies"); if not z then return end
    local spd = z.VectorVelocity.Magnitude; if spd < 2 then return end
    local now = tick()
    aeroBase = aeroBase + 0.08 * (spd - aeroBase)
    if spd > aeroPeak then aeroPeak = spd end
    if aeroBase >= AERO_MIN and spd >= aeroBase * AERO_SPIKE then
        aeroDetected = true; aeroExpiry = now + S.AeroDecay
    end
    if aeroDetected and now >= aeroExpiry then aeroDetected = false end
end

local function ResetAero()
    aeroDetected = false; aeroBase = 0; aeroPeak = 0; aeroExpiry = 0
end

-- ═════════════════════════════ CURVE ENGINE ══
-- Tracks ball angular velocity to detect curving paths (homing, spin abilities).
-- Lower CURVE_THRESH = more sensitive to real curves without false positives.
local CURVE_THRESH  = 0.20   -- rad/s
local CURVE_SAMPLES = 12
local cBuf = {}; local cPtr = 1
local curveAngVel = 0; local curveAxis = Vector3.new(0,1,0); local homingBias = 0
for i=1,CURVE_SAMPLES do cBuf[i]={pos=Vector3.zero, vel=Vector3.zero, t=0} end

local function CurveClear()
    for i=1,CURVE_SAMPLES do cBuf[i]={pos=Vector3.zero, vel=Vector3.zero, t=0} end
    cPtr=1; curveAngVel=0; curveAxis=Vector3.new(0,1,0); homingBias=0
end

local function CurveSample(ball)
    local z = ball:FindFirstChild("zoomies"); if not z then return end
    cBuf[cPtr] = {pos=ball.Position, vel=z.VectorVelocity, t=tick()}
    cPtr = cPtr % CURVE_SAMPLES + 1
end

local function CurveAnalyse()
    local function smp(off) return cBuf[(cPtr-2-off) % CURVE_SAMPLES + 1] end
    local a, b = smp(0), smp(1)
    local dt = a.t - b.t; if dt < 0.004 then return end
    local aM = a.vel.Magnitude; local bM = b.vel.Magnitude
    if aM < 1 or bM < 1 then return end
    local aD = a.vel/aM; local bD = b.vel/bM
    local dot = math.clamp(aD:Dot(bD), -1, 1)
    curveAngVel = curveAngVel + 0.25 * (math.acos(dot)/dt - curveAngVel)
    local ax = bD:Cross(aD)
    if ax.Magnitude > 0.0001 then curveAxis = ax.Unit end
    homingBias = math.clamp(math.abs(aM-bM)/dt/200, 0, 1)
end

local function IsCurving() return S.CurveDetect and curveAngVel > CURVE_THRESH end

local function CurvePredict(ball, lookahead)
    local z = ball:FindFirstChild("zoomies"); if not z then return ball.Position end
    local pos = ball.Position; local vel = z.VectorVelocity; local spd = vel.Magnitude
    if spd < 1 then return pos end
    if curveAngVel < CURVE_THRESH then return pos + vel * lookahead end
    local STEPS = 10; local stepDt = lookahead / STEPS; local curV = vel
    for _ = 1, STEPS do
        curV = CFrame.fromAxisAngle(curveAxis, curveAngVel * stepDt) * curV.Unit * spd
        pos = pos + curV * stepDt
    end
    return pos
end

-- ═════════════════════════════ THRESHOLD ══
-- Returns the firing TTI threshold in seconds.
-- For AutoTiming: base 0.155s + ping/fps/jitter/aero compensations.
-- Manual: just S.TriggerTime + compensations.
-- The per-frame distance floor (MinFireDist) is applied in the main loop.
local function GetThreshold()
    local base = S.AutoTiming and 0.155 or S.TriggerTime
    local pingC  = math.clamp(smoothPing / 2000, 0, 0.04)
    local fpsC   = fpsLow and math.clamp((60-smoothFPS)/60*0.04, 0, 0.04) or 0
    local jitC   = math.clamp(math.sqrt(dtVar) * 1.5, 0, 0.025)
    local aeroC  = (aeroDetected and S.AeroDetect) and S.AeroBoost/1000 or 0
    return base + pingC + fpsC + jitC + aeroC
end

-- ═════════════════════════════════ TTI ══
-- Returns time-to-impact in seconds.
-- Returns math.huge if ball has no velocity data → no premature fire on spawn.
local function GetTTI(ball, hrp, dt)
    local z = ball:FindFirstChild("zoomies")
    if not z then return math.huge end
    local vel = z.VectorVelocity; local spd = vel.Magnitude
    if spd < 0.5 then return math.huge end

    if IsCurving() then
        -- Blend straight TTI with curve-predicted TTI
        local dist = (hrp.Position - ball.Position).Magnitude
        local lookahead = dist / spd
        local pDist = (hrp.Position - CurvePredict(ball, lookahead)).Magnitude
        local blend = math.clamp((curveAngVel - CURVE_THRESH) / 0.80, 0, 0.65)
        local blended = pDist * blend + dist * (1 - blend)
        return math.max(0, blended / spd)
    else
        local predicted = ball.Position + vel * (dt or 1/60)
        local dist = (hrp.Position - predicted).Magnitude
        return math.max(0, dist / spd)
    end
end

-- ═══════════════════════════════ APPROACH CHECK ══
local function IsApproaching(ball, hrp)
    local z = ball:FindFirstChild("zoomies")
    if not z or z.VectorVelocity.Magnitude < 0.5 then return true end
    local toP = hrp.Position - ball.Position
    local len = toP.Magnitude
    if len < 0.01 then return true end
    if S.CurveDetect and IsCurving() then
        local fP = CurvePredict(ball, 0.12)
        return (hrp.Position - fP).Magnitude < len
    end
    return z.VectorVelocity.Unit:Dot(toP / len) > 0.20
end

-- ═══════════════════════════════ AUTO CURVE ══
local acPinTarget    = nil
local acCamRestoring = false

local function GetCurveTarget()
    if acPinTarget and acPinTarget.Character then
        local h = acPinTarget.Character:FindFirstChild("HumanoidRootPart")
        if h then return h end
    end
    local hrp = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local best, bestD = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local eh = p.Character:FindFirstChild("HumanoidRootPart")
            if eh then
                local d = (eh.Position - hrp.Position).Magnitude
                if d < bestD then bestD = d; best = eh end
            end
        end
    end
    return best
end

local function DoAutoCurve()
    if not S.AutoCurve or acCamRestoring then return end
    local tgt = GetCurveTarget(); if not tgt then return end
    Camera.CFrame = CFrame.new(Camera.CFrame.Position, tgt.Position + Vector3.new(0,1.5,0))
    acCamRestoring = true
    task.delay(S.ACSnapDur, function() acCamRestoring = false end)
end

-- ═══════════════════════════════ ANTI CURVE ══
local antiActive = false; local antiExpiry = 0

local function DoAntiCurve()
    if not S.AntiCurve then return end
    local ball = rawget(_G, "__Z0M_ball")  -- will be set in ball tracking
    if not ball or not ball.Parent then return end
    local z = ball:FindFirstChild("zoomies"); if not z then return end
    local spd = z.VectorVelocity.Magnitude; if spd < 1 then return end
    local tgt = GetCurveTarget()
    local dir = tgt and (tgt.Position - ball.Position).Unit or z.VectorVelocity.Unit
    local sv = dir * spd
    pcall(function()
        ball.AssemblyLinearVelocity  = sv
        ball.AssemblyAngularVelocity = Vector3.zero
    end)
    pcall(function() z.VectorVelocity = sv end)
    antiActive = true; antiExpiry = tick() + S.AntiCurveDur
end

-- ═══════════════════════════ PARRY STATE MACHINE ══
-- States: IDLE=0, ARMED=1, FIRED=2
-- IDLE  → ARMED : ball.target == LP.Name (from IDLE only)
-- ARMED → FIRED : TTI ≤ threshold  (we fire exactly once)
-- FIRED → IDLE  : ball.target ~= LP.Name (ball left, safe to re-arm)
--
-- This replaces the old hasParried/ballWasAway dual-flag approach.
-- The only way to re-fire is IDLE→ARMED→FIRED, which requires the
-- ball to have genuinely left us first (FIRED→IDLE transition).
local IDLE  = 0
local ARMED = 1
local FIRED = 2
local parryState  = IDLE
local lastFired   = 0
local MIN_REFIRE  = 0.30  -- hard floor between fires (safety net)

local currentBall = nil
local ballConn    = nil
local cachedHRP   = nil
_G.__Z0M_ball     = nil   -- exposed for AntiCurve

-- Triggerbot state
local tbActive     = false
local tbToggleOn   = false
local tbLastFire   = 0
local autoParryBak = true

-- CPS measurement
local cpsFireBucket = 0; local cpsActual = 0; local cpsMeasTimer = 0

local function FireParry()
    lastFired = tick()
    VIM:SendMouseButtonEvent(0, 0, 0, true,  game, 0)
    VIM:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    DoAutoCurve()
    DoAntiCurve()
end

local function ActivateTB()
    if tbActive then return end
    autoParryBak = S.AutoParry; S.AutoParry = false; tbActive = true
    if _G.__Z0M_SyncTB then _G.__Z0M_SyncTB() end
end
local function DeactivateTB()
    if not tbActive then return end
    tbActive = false; S.AutoParry = autoParryBak
    if _G.__Z0M_SyncTB then _G.__Z0M_SyncTB() end
end

-- ═══════════════════════════════ BALL TRACKING ══
local function GetBall()
    if not BallFolder then return nil end
    -- Priority: explicit realBall attr → name "Ball" → any BasePart/Model
    for _, b in ipairs(BallFolder:GetChildren()) do
        if b:GetAttribute("realBall") then return b end
    end
    for _, b in ipairs(BallFolder:GetChildren()) do
        if b.Name == "Ball" then return b end
    end
    for _, b in ipairs(BallFolder:GetChildren()) do
        if b:IsA("BasePart") or b:IsA("Model") then return b end
    end
    return nil
end

local function DisconnectBall()
    if ballConn then ballConn:Disconnect(); ballConn = nil end
    currentBall = nil; _G.__Z0M_ball = nil
    parryState = IDLE; tbLastFire = 0
    CurveClear(); ResetAero()
end

local function BindBall(ball)
    if ballConn then ballConn:Disconnect(); ballConn = nil end

    currentBall = ball; _G.__Z0M_ball = ball
    parryState  = IDLE
    lastFired   = 0
    tbLastFire  = 0
    CurveClear(); ResetAero()

    if not ball then return end

    -- Immediately check current target — ball may ALREADY be targeting us
    if ball:GetAttribute("target") == LP.Name then
        parryState = ARMED
    end

    -- Watch for target changes
    ballConn = ball:GetAttributeChangedSignal("target"):Connect(function()
        CurveClear(); ResetAero()
        local tgt = ball:GetAttribute("target")
        if tgt == LP.Name then
            -- Ball just targeted us — only arm from IDLE
            if parryState == IDLE then
                parryState = ARMED
            end
        else
            -- Ball left us — reset to IDLE so we can arm again next time
            parryState = IDLE
        end
    end)
end

local function SetupBallFolder()
    if not BallFolder then return end
    Con(BallFolder.ChildAdded:Connect(function(child)
        task.spawn(function()
            -- Bind immediately — don't wait
            if child and child.Parent then BindBall(child) end
            -- Sanity re-check after brief delay (attributes may not be set yet)
            task.wait(0.15)
            local b = GetBall()
            if b and b ~= currentBall then BindBall(b) end
        end)
    end))
    Con(BallFolder.ChildRemoved:Connect(function()
        task.wait()
        local b = GetBall()
        if b then BindBall(b) else DisconnectBall() end
    end))
    BindBall(GetBall())
end

local function SetupCharacter(char)
    parryState = IDLE; cachedHRP = nil
    BindBall(GetBall())
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then cachedHRP = hrp
    else task.spawn(function() cachedHRP = char:WaitForChild("HumanoidRootPart", 10) end) end
end

SetupBallFolder()
SetupCharacter(LP.Character)
Con(LP.CharacterAdded:Connect(SetupCharacter))

-- ═══════════════════════════════════ MAIN LOOP ══
Con(RunService.PreSimulation:Connect(function(dt)
    UpdatePing(); UpdateFPS(dt)

    if currentBall and currentBall.Parent then
        if S.CurveDetect then CurveSample(currentBall); CurveAnalyse() end
        UpdateAero(currentBall)
    end

    -- CPS meter
    cpsMeasTimer = cpsMeasTimer + dt
    while cpsMeasTimer >= 1 do
        cpsActual = cpsFireBucket; cpsFireBucket = 0; cpsMeasTimer = cpsMeasTimer - 1
    end

    -- Anti-curve expiry (single-shot, just clear the flag)
    if antiActive and tick() >= antiExpiry then antiActive = false end

    -- ── Triggerbot ────────────────────────────────────────────────
    if tbActive then
        local ball = currentBall; local hrp = cachedHRP
        if ball and ball.Parent and hrp and ball:GetAttribute("target") == LP.Name then
            local cps = S.TBUseExp and S.TBExpCps or S.TBCps
            local now = tick()
            if now - tbLastFire >= 1 / math.max(cps, 1) then
                tbLastFire = now; cpsFireBucket = cpsFireBucket + 1
                FireParry()
            end
        end
        return
    end

    if not S.AutoParry then return end

    -- Recover lost ball ref
    if not (currentBall and currentBall.Parent) then
        local b = GetBall(); if b then BindBall(b) end
    end

    local ball = currentBall; if not (ball and ball.Parent) then return end
    local hrp  = cachedHRP;   if not hrp then return end

    -- Belt-and-suspenders: sync state from attribute in case signal was missed
    local tgt = ball:GetAttribute("target")
    if tgt == LP.Name then
        if parryState == IDLE then parryState = ARMED end
    else
        if parryState ~= IDLE then parryState = IDLE end
        return
    end

    if parryState ~= ARMED then return end

    local z    = ball:FindFirstChild("zoomies")
    local spd  = z and z.VectorVelocity.Magnitude or 0
    local dist = (hrp.Position - ball.Position).Magnitude

    -- Don't react if ball is right on top of us (already past window)
    if dist < 1.5 then return end

    -- Approach check — ball must actually be coming toward us
    if not IsApproaching(ball, hrp) then return end

    -- Compute adaptive threshold
    local threshold = GetThreshold()
    if S.AutoTiming and spd > 0.5 then
        -- Distance floor: fire at least S.MinFireDist studs away
        -- This fixes "too late" on slow or freshly-spawned balls
        threshold = math.max(threshold, math.min(S.MinFireDist / spd, 2.0))
    end

    -- Clash mode: fire immediately once ball is close enough
    if S.ClashMode and dist <= S.ClashDist then
        if tick() - lastFired < MIN_REFIRE then return end
        parryState = FIRED; FireParry(); return
    end

    -- Static ball: use distance trigger
    if spd < 0.5 then
        if dist <= 5 then
            if tick() - lastFired < MIN_REFIRE then return end
            parryState = FIRED; FireParry()
        end
        return
    end

    -- Normal TTI-based trigger
    local tti = GetTTI(ball, hrp, dt)
    if tti <= threshold then
        if tick() - lastFired < MIN_REFIRE then return end
        parryState = FIRED; FireParry()
    end
end))

-- ══════════════════════════════════════ ESP ══
local espData = {}
local ABILITY_KEYS = {
    "EquippedAbility","equippedAbility","Ability","ability","AbilityName","abilityName",
    "SelectedAbility","selectedAbility","CurrentAbility","currentAbility",
    "PlayerAbility","playerAbility","skillName","SkillName",
}

local function ScanAbility(obj)
    if not obj then return nil end
    for _, k in ipairs(ABILITY_KEYS) do
        local v = obj:GetAttribute(k)
        if v then
            local s = tostring(v)
            if s ~= "" and s ~= "None" and s ~= "nil" and s ~= "0" and s ~= "false" then return s end
        end
    end
    local ok, attrs = pcall(function() return obj:GetAttributes() end)
    if ok and attrs then
        for k, v in pairs(attrs) do
            local lk = k:lower()
            if lk:find("abilit") or lk:find("skill") or lk:find("power") then
                local s = tostring(v)
                if s ~= "" and s ~= "false" and s ~= "0" and s ~= "nil" and s ~= "None" then return s end
            end
        end
    end
    return nil
end

local function GetAbility(player)
    local ab = ScanAbility(player); if ab then return ab end
    local char = player.Character
    if char then
        ab = ScanAbility(char); if ab then return ab end
        local hum = char:FindFirstChild("Humanoid")
        if hum then ab = ScanAbility(hum); if ab then return ab end end
        for _, obj in ipairs(char:GetDescendants()) do
            if obj:IsA("StringValue") then
                local lk = obj.Name:lower()
                if (lk:find("abilit") or lk:find("skill") or lk:find("power"))
                    and obj.Value ~= "" and obj.Value ~= "None" then return obj.Value end
            end
        end
    end
    return "—"
end

local function ClearESP(player)
    local d = espData[player]; if not d then return end
    for _, c in ipairs(d.conns) do pcall(function() c:Disconnect() end) end
    for _, inst in ipairs(d.instances) do
        if typeof(inst) == "Instance" and inst.Parent then pcall(function() inst:Destroy() end) end
    end
    espData[player] = nil
end

local function ClearAllESP() for p in pairs(espData) do ClearESP(p) end; espData = {} end

local function BuildESP(player)
    ClearESP(player); if player == LP then return end
    if not S.PlayerESP and not S.AbilityESP then return end
    local d = {conns={}, instances={}}; espData[player] = d
    local function AI(o) d.instances[#d.instances+1]=o end
    local function AC(c) d.conns[#d.conns+1]=c end

    local function Build(char)
        for _, i in ipairs(d.instances) do
            if typeof(i)=="Instance" and i.Parent then pcall(function() i:Destroy() end) end
        end
        d.instances = {}
        local head = char:WaitForChild("Head", 5); if not head then return end
        local bb = Instance.new("BillboardGui")
        bb.Adornee=head; bb.AlwaysOnTop=true; bb.LightInfluence=0
        bb.Size=UDim2.new(0,160,0,(S.PlayerESP and S.AbilityESP) and 38 or 20)
        bb.StudsOffset=Vector3.new(0, S.AbilityESP and 3.4 or 2.8, 0)
        bb.Parent=head; AI(bb)

        if S.PlayerESP then
            local lbl = Instance.new("TextLabel", bb)
            lbl.Size=UDim2.new(1,0,0,18); lbl.BackgroundTransparency=1
            lbl.Font=Enum.Font.GothamBold; lbl.TextSize=13
            lbl.TextXAlignment=Enum.TextXAlignment.Center
            lbl.TextStrokeTransparency=0.3; lbl.ZIndex=5
            lbl.Text=player.DisplayName; AI(lbl)
            local lastT=0
            AC(RunService.Heartbeat:Connect(function()
                if not lbl.Parent then return end
                local now=tick(); if now-lastT<0.1 then return end; lastT=now
                local ball=currentBall
                lbl.TextColor3=(ball and ball.Parent and ball:GetAttribute("target")==LP.Name)
                    and Color3.fromRGB(255,60,60) or Color3.fromRGB(255,228,60)
            end))
        end

        if S.AbilityESP then
            local al = Instance.new("TextLabel", bb)
            al.Size=UDim2.new(1,0,0,16)
            al.Position=UDim2.new(0,0,0,S.PlayerESP and 20 or 2)
            al.BackgroundTransparency=1; al.Font=Enum.Font.Gotham; al.TextSize=11
            al.TextXAlignment=Enum.TextXAlignment.Center
            al.TextColor3=Color3.fromRGB(160,228,255)
            al.TextStrokeTransparency=0.45; al.ZIndex=5; AI(al)
            local lastA=0
            AC(RunService.Heartbeat:Connect(function()
                if not al.Parent then return end
                local now=tick(); if now-lastA<0.5 then return end; lastA=now
                al.Text = "⚡ "..GetAbility(player)
            end))
        end
    end

    if player.Character then task.spawn(function() Build(player.Character) end) end
    AC(player.CharacterAdded:Connect(function(c) task.wait(0.1); Build(c) end))
end

local function RebuildAllESP()
