local function SerializeS()
    local t={}; for _,k in ipairs(CONFIG_KEYS) do t[k]=S[k] end
    t.TBKey=tostring(S.TBKey); t.MenuKey=tostring(S.MenuKey); return t
end
local function DeserializeS(t)
    for _,k in ipairs(CONFIG_KEYS) do if t[k]~=nil then S[k]=t[k] end end
    for _,f in ipairs({"TBKey","MenuKey"}) do
        if t[f] then
            local s=tostring(t[f]):gsub("Enum%.KeyCode%.","")
            local ok,v=pcall(function() return Enum.KeyCode[s] end)
            if ok and v then S[f]=v end
        end
    end
end

local function LoadConfigs()
    local ok,data=pcall(function()
        if readfile then return HttpService:JSONDecode(readfile(CONFIG_FILE)) end
        return nil
    end)
    configs=(ok and type(data)=="table") and data or {}
    for i=1,CONFIG_SLOTS do
        if not configs[i] then configs[i]={name="Slot "..i,data=nil} end
    end
end
local function SaveConfigs()
    pcall(function() if writefile then writefile(CONFIG_FILE,HttpService:JSONEncode(configs)) end end)
end
