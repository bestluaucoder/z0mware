    Tr.Size=UDim2.new(1,0,0,tH); Tr.Position=UDim2.new(0,0,1,-tH)
    Tr.BackgroundColor3=C.track; Tr.BorderSizePixel=0; Corner(3,Tr)
    local r0=math.clamp((S[key]-minV)/(maxV-minV),0,1)
    local Fill=Instance.new("Frame",Tr)
