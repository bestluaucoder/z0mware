-- ══════════════════════════════ HEADER BUTTONS ══
local minimized=false
MinBtn.MouseButton1Click:Connect(function()
    if isMobile then
        Main.Visible=false
        TweenService:Create(ToggleBtn,TweenInfo.new(0.12),{BackgroundColor3=Color3.fromRGB(10,11,20)}):Play()
        return
    end
    minimized=not minimized
    TweenService:Create(Main,TweenInfo.new(0.18,Enum.EasingStyle.Quart),{
        Size=minimized and UDim2.new(0,W,0,HMIN) or UDim2.new(0,W,0,HFUL)
    }):Play()
    MinBtn.Text=minimized and "+" or "─"
end)
CloseBtn.MouseButton1Click:Connect(function()
    TweenService:Create(Main,TweenInfo.new(0.18,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Size=UDim2.new(0,0,0,0)}):Play()
    task.delay(0.25,function() ScreenGui:Destroy() end)
end)
for _,btn in ipairs({MinBtn,CloseBtn}) do
    local orig=btn.BackgroundColor3
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn,TweenInfo.new(0.1),{
            BackgroundColor3=btn==CloseBtn and Color3.fromRGB(210,50,50) or Color3.fromRGB(38,36,58)
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn,TweenInfo.new(0.1),{BackgroundColor3=orig}):Play()
    end)
end

-- ════════════════════════════ INPUT HANDLER ══
Con(UIS.InputBegan:Connect(function(i, gpe)
    -- Keybind capture
    if _G.__Z0M_MKListen and _G.__Z0M_MKListen() then
        if i.UserInputType==Enum.UserInputType.Keyboard then
            if i.KeyCode==Enum.KeyCode.Escape then _G.__Z0M_MKCancel()
            else _G.__Z0M_MKSet(i.KeyCode) end
        end; return
    end
    if _G.__Z0M_TBListen and _G.__Z0M_TBListen() then
        if i.UserInputType==Enum.UserInputType.Keyboard then
            if i.KeyCode==Enum.KeyCode.Escape then _G.__Z0M_TBCancel()
            else _G.__Z0M_TBSet(i.KeyCode) end
        end; return
    end
    if gpe then return end
    if not isMobile and i.UserInputType==Enum.UserInputType.Keyboard then
        -- Triggerbot key
        if S.TBEnabled and i.KeyCode==S.TBKey then
            if S.TBMode=="hold" then ActivateTB()
            else tbToggleOn=not tbToggleOn; if tbToggleOn then ActivateTB() else DeactivateTB() end end
        end
        -- Quick parry toggle (F)
        if i.KeyCode==Enum.KeyCode.F and not tbActive then
            S.AutoParry=not S.AutoParry
            if _G.__Z0M_RefreshStatus then _G.__Z0M_RefreshStatus() end
        end
        -- Menu key
        if i.KeyCode==S.MenuKey then Main.Visible=not Main.Visible end
    end
end))

Con(UIS.InputEnded:Connect(function(i)
    if not isMobile and S.TBEnabled and S.TBMode=="hold" and i.KeyCode==S.TBKey then
        DeactivateTB()
    end
end))

-- ═══════════════════════════ LIVE GUI UPDATE ══
local guiT=0
Con(RunService.Heartbeat:Connect(function(dt)
    guiT=guiT+dt; if guiT<0.05 then return end; guiT=0

    if _G.__Z0M_UpdateMain   then _G.__Z0M_UpdateMain()   end
    if _G.__Z0M_UpdateDetect then _G.__Z0M_UpdateDetect() end
    if _G.__Z0M_UpdateFPS    then _G.__Z0M_UpdateFPS()    end

    if S.ShowCPS and CPSOv.Visible then
        local tgt = S.TBUseExp and S.TBExpCps or S.TBCps
        if tbActive then
            CValLbl.Text=string.format("%d / %d CPS",cpsActual,tgt)
            CValLbl.TextColor3=C.red; CTitleLbl.Text="CPS  (FIRING)"
        else
            CValLbl.Text=string.format("%d CPS",tgt)
            CValLbl.TextColor3=C.accent; CTitleLbl.Text="CPS COUNTER"
        end
        local fc=smoothFPS>=55 and C.green or smoothFPS>=35 and C.yellow or C.red
        CSubLbl.TextColor3=fc
        CSubLbl.Text=string.format("FPS:%.0f | Ping:%.0fms",smoothFPS,displayPing)
    end
end))

