-- Settings injection from _G.
-- All three of the following syntaxes work before loadstring():
--
--   (A)  S = { AutoParry=true, TBExpCps=172, ... }       ← drop "local"
--   (B)  _G.Z0M = { AutoParry=true, TBExpCps=172, ... }  ← explicit _G
--   (C)  _G.Z0M_Settings = { ... }                        ← legacy alias
--
-- NOTE: "local S" is scoped to the caller's chunk and is invisible inside
-- loadstring(). Removing the word "local" makes S a global — which IS visible.
-- Precedence (last wins per key): Z0M_Settings → Z0M → S
do
    local function ApplyTable(src)
        if type(src) ~= "table" then return end
        for k, v in pairs(src) do
            if S[k] ~= nil then S[k] = v end
        end
        for _, key in ipairs({"TBKey","MenuKey"}) do
            local raw = src[key]
            if raw then
                if typeof(raw) == "EnumItem" then
                    S[key] = raw
                else
                    local stripped = tostring(raw):gsub("Enum%.KeyCode%.","")
                    local ok, kc = pcall(function() return Enum.KeyCode[stripped] end)
                    if ok and kc then S[key] = kc end
                end
            end
        end
    end
    ApplyTable(_G.Z0M_Settings)
    ApplyTable(_G.Z0M)
    ApplyTable(_G.S)
end

-- ═══════════════════════════════════ GLOBAL INPUT STATE ══
-- Single shared state for all drags and sliders.
-- Using UIS.InputChanged (fires globally) instead of per-element
-- InputChanged (stops when cursor leaves element bounds on PC).
local _drag  = nil   -- { frame, origin, startPos, thresh?, movedRef? }
local _slide = nil   -- function(screenX)

local _conns = {}
local function Con(c) _conns[#_conns+1] = c; return c end

Con(UIS.InputChanged:Connect(function(i)
    local t = i.UserInputType
    if t ~= Enum.UserInputType.MouseMovement and t ~= Enum.UserInputType.Touch then return end
    local pos = i.Position
    if _drag then
        local d = pos - _drag.origin
        if _drag.movedRef then
            if d.Magnitude > (_drag.thresh or 8) then _drag.movedRef.v = true end
        end
        local sp = _drag.startPos
        _drag.frame.Position = UDim2.new(sp.X.Scale, sp.X.Offset + d.X, sp.Y.Scale, sp.Y.Offset + d.Y)
    end
    if _slide then _slide(pos.X) end
end))

Con(UIS.InputEnded:Connect(function(i)
    local t = i.UserInputType
    if t == Enum.UserInputType.MouseButton1 or t == Enum.UserInputType.Touch then
        _drag  = nil
        _slide = nil
    end
end))

local function MakeDraggable(frame, handle, thresh, movedRef)
    handle = handle or frame
    handle.InputBegan:Connect(function(i)
        local t = i.UserInputType
        if t ~= Enum.UserInputType.MouseButton1 and t ~= Enum.UserInputType.Touch then return end
        _drag = { frame=frame, origin=i.Position, startPos=frame.Position, thresh=thresh, movedRef=movedRef }
    end)
end

